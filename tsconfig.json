{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "paths": {
      "~~/*": ["../or3-chat/*"],
      "~~": ["../or3-chat"],
      "~/*": ["../or3-chat/app/*"],
      "~": ["../or3-chat/app"],
      "#imports": ["../or3-chat/.nuxt/imports"],
      "or3-scroll": ["../or3-chat/node_modules/or3-scroll"]
    }
  },
  "include": ["plugin.client.ts", "src/**/*.ts", "src/**/*.vue", "scripts/**/*.mjs"],
  "exclude": ["node_modules", "dist"]
}
